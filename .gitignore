# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# NOTE: .env.example is NOT ignored and should be committed

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Google Cloud credentials
service-account.json
docs/musicapp-*.json
*.json.key
credentials.json

# Music files (too large for git)
public/music/

# IDE / tool artifacts
.claude/
.playwright-mcp/

# Accidental empty files
npm
npx
nul
ts-node
project_02_music@0.1.0
