# ============================================
# SH Music App - Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# cp .env.example .env
#
# IMPORTANT: Never commit the .env file to version control.
# ============================================

# ------------------------------------------
# Database (REQUIRED)
# ------------------------------------------
# PostgreSQL connection string for Prisma ORM
# Example for Neon: postgresql://user:password@host/dbname?sslmode=require
# Example for local: postgresql://postgres:password@localhost:5432/music_db
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ------------------------------------------
# Google Drive OAuth (REQUIRED for file uploads/streaming)
# ------------------------------------------
# OAuth 2.0 credentials from Google Cloud Console
# https://console.cloud.google.com/apis/credentials
GOOGLE_DRIVE_CLIENT_ID="your-google-drive-client-id.apps.googleusercontent.com"
GOOGLE_DRIVE_CLIENT_SECRET="your-google-drive-client-secret"
GOOGLE_DRIVE_REDIRECT_URI="http://localhost:3000/api/auth/callback"
GOOGLE_DRIVE_REFRESH_TOKEN="your-google-drive-refresh-token"

# ------------------------------------------
# Google Service Account (REQUIRED for Drive folder/file listing)
# ------------------------------------------
# Service account credentials from Google Cloud Console
# Used for server-to-server Google Drive and Sheets API access
GOOGLE_CLIENT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ------------------------------------------
# Google Sheets (OPTIONAL - legacy song data source)
# ------------------------------------------
# The ID of the Google Spreadsheet containing song data
# Found in the spreadsheet URL: https://docs.google.com/spreadsheets/d/{SHEET_ID}/edit
GOOGLE_SHEET_ID="your-google-sheet-id"

# ------------------------------------------
# Gemini AI (OPTIONAL - lyrics generation)
# ------------------------------------------
# API key for Google Generative AI (Gemini)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key"

# ------------------------------------------
# Local Music Files (OPTIONAL)
# ------------------------------------------
# Absolute path to the directory containing local music files
# Defaults to C:\AI_MUSIC if not set
AI_MUSIC_DIR="C:\\AI_MUSIC"

# ------------------------------------------
# App Configuration (OPTIONAL)
# ------------------------------------------
# Base URL of the application
# Defaults to http://localhost:3000 if not set
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
